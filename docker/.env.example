# Docker Compose 환경 변수 예시 / Docker Compose environment variables example
# 이 파일을 docker/.env로 복사한 후 값을 설정하세요.
# Copy this file to docker/.env and set the values.

# Database configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pgdemo
SPRING_DATASOURCE_USERNAME=pgdemo
SPRING_DATASOURCE_PASSWORD=<YOUR_DB_PASSWORD>
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/pgdemo

# JWT secret (must be 32+ chars for HS256)
JWT_SECRET=<YOUR_JWT_SECRET_MINIMUM_32_CHARACTERS>

# Seeder passwords (for DataSeeder demo accounts)
# NOTE: These are only used when running with seeder profile.
# NOTE: 이 값들은 seeder 프로필로 실행할 때만 사용됩니다.
SEEDER_PASSWORD_OPERATOR=<OPERATOR_ADMIN_PASSWORD>
SEEDER_PASSWORD_HQ_ADMIN=<HQ_ADMIN_PASSWORD>
SEEDER_PASSWORD_HQ_MANAGER=<HQ_MANAGER_PASSWORD>
SEEDER_PASSWORD_MERCHANT=<MERCHANT_ADMIN_PASSWORD>
