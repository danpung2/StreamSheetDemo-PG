FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY traffic-generate.sh /app/traffic-generate.sh
COPY scripts/pg_load_generator.py /app/scripts/pg_load_generator.py

RUN chmod +x /app/traffic-generate.sh

ENTRYPOINT ["/app/traffic-generate.sh"]
